    <script type="text/babel">
        const { useState, useEffect, useMemo } = React;

        function App() {
            // Theme setup
            const [darkMode, setDarkMode] = useState(false);
            
            // Tab states: 'translator' | 'dictionary' | 'quiz' | 'submit' | 'deploy'
            const [activeTab, setActiveTab] = useState('translator');

            // Dictionary Data (persisted in LocalStorage if supported)
            const [dictionary, setDictionary] = useState(() => {
                const saved = localStorage.getItem('mz_slang_dict');
                return saved ? JSON.parse(saved) : INITIAL_DICTIONARY;
            });

            // Save dictionary when modified
            useEffect(() => {
                localStorage.setItem('mz_slang_dict', JSON.stringify(dictionary));
            }, [dictionary]);

            // Dark Mode Class Handler
            useEffect(() => {
                if (darkMode) {
                    document.documentElement.classList.add('dark');
                } else {
