    <script type="text/babel">
        function TranslatorSection({ dictionary, triggerToast }) {
            const [inputText, setInputText] = useState('');
            const [copied, setCopied] = useState(false);

            // Pre-process dictionary sorted by word length desc to avoid partial matches
            const sortedSlangs = useMemo(() => {
                return [...dictionary].sort((a, b) => b.word.length - a.word.length);
            }, [dictionary]);

            // Clear Input
            const handleClear = () => {
                setInputText('');
            };

            // Sample sentences to play with
            const loadSample = (type) => {
                if (type === 1) {
                    setInputText("오늘 분좋카가서 갓생러인 친구랑 만났는데, 점메추좀 해달라니까 너 T야? 시전하더라... 억까 당해서 억텐 부렸음 ㅠ");
                } else if (type === 2) {
                    setInputText("회사 과제가 너무 많아서 스불재 그 자체인데 중꺾그마 마인드로 일단 오늘 퇴근 푸드는 곱창이랑 엽떡 캘박했음. 내또출 실화냐?");
                } else {
                    setInputText("부장님이 일을 알아서 딱 깔끔하고 센스있게 해달라길래 알잘딱깔센 발휘해봤지. 역시 내 기획안 폼미쳤다 하셨음!");
                }
            };

            // Real-time Translation Core Algorithm
            const parsedOutput = useMemo(() => {
                if (!inputText.trim()) return <span className="text-slate-400 dark:text-slate-500">번역 결과가 이곳에 실시간으로 출력되며, 신조어는 하이라이트 표시됩니다. Hover/터치 시 상세 뜻과 예시를 바로 보여줍니다.</span>;

                // Build a Regex of all slang keys
                const wordsRegexStr = sortedSlangs.map(s => escapeRegExp(s.word)).join('|');
                if (!wordsRegexStr) return <span>{inputText}</span>;

                const regex = new RegExp(`(${wordsRegexStr})`, 'g');
                const parts = inputText.split(regex);

                return parts.map((part, index) => {
                    const matchedSlang = sortedSlangs.find(s => s.word === part);
                    if (matchedSlang) {
                        return (
                            <span 
                                key={index} 
                                className="relative inline-block group border-b-2 border-indigo-500 text-indigo-600 dark:text-indigo-400 font-bold bg-indigo-50 dark:bg-indigo-950/40 px-1 rounded cursor-pointer mx-0.5 transition-all hover:bg-indigo-500 hover:text-white dark:hover:bg-indigo-600 dark:hover:text-white"
                                title={`원래 표현: ${matchedSlang.standard}`}
                            >
                                {part}
                                {/* Tooltip component */}
                                <span className="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-72 bg-slate-900 text-white dark:bg-slate-800 text-xs rounded-xl p-3.5 shadow-xl hidden group-hover:block z-50 pointer-events-none transition-all duration-300 transform scale-95 origin-bottom">
                                    <span className="flex items-center justify-between border-b border-slate-700 pb-1.5 mb-2">
                                        <strong className="text-indigo-300 text-sm">「{matchedSlang.word}」</strong>
                                        <span className="text-[10px] text-slate-400 bg-slate-800 px-1.5 py-0.5 rounded-full">{matchedSlang.category}</span>
                                    </span>
                                    <p className="font-semibold text-slate-100 mb-1">번역: {matchedSlang.standard}</p>
                                    <p className="text-slate-300 leading-relaxed mb-2">{matchedSlang.definition}</p>
                                    <p className="text-[11px] text-indigo-200 italic">Ex: "{matchedSlang.example}"</p>
                                    <span className="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-slate-900 dark:border-t-slate-800"></span>
                                </span>
                            </span>
                        );
                    }
                    return <span key={index}>{part}</span>;
                });
            }, [inputText, sortedSlangs]);

            // Helper to escape special regex chars
            function escapeRegExp(string) {
                return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            }

            // Copy translated outcome
            const handleCopyText = () => {
                if (!inputText) return;
                // Formulate a plain text translation string
                let translatedPlain = inputText;
                sortedSlangs.forEach(s => {
                    const reg = new RegExp(escapeRegExp(s.word), 'g');
                    translatedPlain = translatedPlain.replace(reg, `${s.word}(해석: ${s.standard})`);
                });

                // Standard legacy command fallback due to sandbox restrictions
                const el = document.createElement('textarea');
                el.value = translatedPlain;
                document.body.appendChild(el);
                el.select();
                document.execCommand('copy');
                document.body.removeChild(el);

                setCopied(true);
                triggerToast('해석 주석이 추가된 전체 텍스트가 클립보드에 복사되었습니다!');
                setTimeout(() => setCopied(false), 2000);
            };

            // Trigger lucide on load
            useEffect(() => {
                if (window.lucide) window.lucide.createIcons();
            }, []);

            return (
                <div className="space-y-8 animate-fadeIn">
                    {/* Intro */}
                    <div className="text-center max-w-2xl mx-auto space-y-2">
                        <span className="text-xs font-bold text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-950/60 px-3 py-1.5 rounded-full">스마트 실시간 분석 & 주석 번역기</span>
                        <h2 className="text-3xl md:text-4xl font-extrabold tracking-tight">요즘 신조어, 한눈에 간편 해석!</h2>
                        <p className="text-sm text-slate-500 dark:text-slate-400">
                            문장 통째로 작성해 보세요. 인공지능이 탑재된 듯 내장 신조어 사전을 실시간 대조하여 숨은 진짜 의미를 즉각 표시해 줍니다.
                        </p>
                    </div>

                    {/* Interactive Showcase Panel */}
                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        {/* Input Area */}
                        <div className="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-md flex flex-col h-96 relative overflow-hidden">
                            <div className="flex items-center justify-between px-4 py-3 border-b border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50">
                                <div className="flex items-center space-x-2 text-slate-700 dark:text-slate-300">
                                    <i data-lucide="pen-tool" className="w-4 h-4"></i>
                                    <span className="text-xs font-bold">슬랭 & 신조어가 포함된 글 작성</span>
                                </div>
                                <div className="flex items-center space-x-2">
                                    <button 
                                        onClick={handleClear}
                                        className="text-xs text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 flex items-center space-x-1 px-1.5 py-1 rounded">
                                        <i data-lucide="trash-2" className="w-3.5 h-3.5"></i>
                                        <span>초기화</span>
                                    </button>
                                </div>
                            </div>
                            <textarea
                                value={inputText}
                                onChange={(e) => setInputText(e.target.value)}
                                placeholder="예: '오늘 분좋카 가서 디토하고 갓생살기 다짐하며 오운완완료함!'을 작성해 보세요."
                                className="flex-1 p-5 resize-none bg-transparent outline-none text-slate-800 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 leading-relaxed text-sm md:text-base"
                            />
                            {/* Fast-load Templates */}
                            <div className="px-4 py-3 border-t border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/30 flex items-center space-x-2 flex-wrap gap-y-1">
                                <span className="text-[11px] font-bold text-slate-400 dark:text-slate-500">테스트용 문장:</span>
                                <button onClick={() => loadSample(1)} className="text-[11px] font-medium bg-slate-200 dark:bg-slate-700 hover:bg-indigo-100 hover:text-indigo-600 dark:hover:bg-indigo-950 px-2 py-1 rounded-md transition-colors">⚡ 일상 대화</button>
                                <button onClick={() => loadSample(2)} className="text-[11px] font-medium bg-slate-200 dark:bg-slate-700 hover:bg-indigo-100 hover:text-indigo-600 dark:hover:bg-indigo-950 px-2 py-1 rounded-md transition-colors">💼 직장인의 밤</button>
                                <button onClick={() => loadSample(3)} className="text-[11px] font-medium bg-slate-200 dark:bg-slate-700 hover:bg-indigo-100 hover:text-indigo-600 dark:hover:bg-indigo-950 px-2 py-1 rounded-md transition-colors">🔥 칭찬 일색</button>
                            </div>
                        </div>

                        {/* Output Translated Area */}
                        <div className="bg-gradient-to-br from-indigo-50/20 via-white to-pink-50/10 dark:from-slate-800 dark:to-slate-900 rounded-2xl border border-indigo-200 dark:border-slate-700 shadow-lg flex flex-col h-96 overflow-hidden">
                            <div className="flex items-center justify-between px-4 py-3 border-b border-indigo-100 dark:border-slate-700 bg-indigo-50/50 dark:bg-slate-800/50">
                                <div className="flex items-center space-x-2 text-indigo-700 dark:text-indigo-300">
                                    <i data-lucide="sparkles" className="w-4 h-4 animate-wave"></i>
                                    <span className="text-xs font-bold">인공지능 표준어 직역기</span>
                                </div>
                                <button 
                                    onClick={handleCopyText}
                                    disabled={!inputText}
                                    className={`text-xs flex items-center space-x-1.5 px-3 py-1.5 rounded-lg font-bold transition-all ${inputText ? 'bg-indigo-600 hover:bg-indigo-700 text-white shadow-md' : 'bg-slate-100 text-slate-400 dark:bg-slate-800 dark:text-slate-600 cursor-not-allowed'}`}>
