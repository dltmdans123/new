                                    <span>{copied ? "복사 완료!" : "주석 포함 복사"}</span>
                                </button>
                            </div>
                            <div className="flex-1 p-6 overflow-y-auto leading-relaxed text-sm md:text-base whitespace-pre-line text-slate-700 dark:text-slate-300">
                                {parsedOutput}
                            </div>
                        </div>
                    </div>

                    {/* Dictionary Tip Banner */}
                    <div className="bg-slate-100 dark:bg-slate-800/60 rounded-xl p-4 flex items-start space-x-3 text-xs leading-relaxed text-slate-500 dark:text-slate-400">
