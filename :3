    <script type="text/babel">
        function QuizSection({ triggerToast }) {
            const [gameState, setGameState] = useState('start'); // 'start' | 'playing' | 'result'
            const [currentIdx, setCurrentIdx] = useState(0);
            const [score, setScore] = useState(0);
            const [selectedAnswer, setSelectedAnswer] = useState(null);
            const [isAnswered, setIsAnswered] = useState(false);

            const startQuiz = () => {
                setGameState('playing');
                setCurrentIdx(0);
                setScore(0);
                setSelectedAnswer(null);
                setIsAnswered(false);
            };

            const handleOptionClick = (optionIdx) => {
                if (isAnswered) return;
                setSelectedAnswer(optionIdx);
                setIsAnswered(true);

                if (optionIdx === QUIZ_QUESTIONS[currentIdx].correct) {
                    setScore(prev => prev + 1);
                }
            };

            const handleNext = () => {
                if (currentIdx < QUIZ_QUESTIONS.length - 1) {
                    setCurrentIdx(prev => prev + 1);
                    setSelectedAnswer(null);
                    setIsAnswered(false);
                } else {
                    setGameState('result');
                }
            };

            // Score evaluation logic
            const getResultType = () => {
                const total = QUIZ_QUESTIONS.length;
                const ratio = score / total;
                if (ratio === 1) return { title: '👑 신조어 마스터 (완벽 인싸)', desc: '트렌드를 완벽하게 지배하는 신조어 고수입니다. MZ세대 최전선에서 소통할 준비가 완벽히 되셨네요!' };
                if (ratio >= 0.6) return { title: '😎 힙한 일반인 (중간 인싸)', desc: '소외감 느끼지 않고 무리 없이 원만한 카톡 소통이 가능한 센스쟁이입니다.' };
                return { title: '👴 트렌드 구조 요망 (갓반인)', desc: '줄임말 소통에 약간 피로감을 느끼시나요? 이 웹 사전 번역기를 자주 활용하시면 트렌드 정복이 금방 가능합니다!' };
            };

            // Trigger icons update
            useEffect(() => {
                if (window.lucide) window.lucide.createIcons();
            }, [gameState, currentIdx, isAnswered]);

            return (
                <div className="max-w-xl mx-auto bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-xl overflow-hidden animate-fadeIn">
                    
                    {gameState === 'start' && (
                        <div className="p-8 text-center space-y-5">
                            <div className="w-16 h-16 rounded-2xl bg-indigo-50 dark:bg-indigo-950/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mx-auto text-2xl font-black">
                                <i data-lucide="trophy" className="w-8 h-8"></i>
                            </div>
                            <div className="space-y-1">
                                <h2 className="text-2xl font-extrabold text-slate-900 dark:text-white">나의 신조어 문해력 테스트</h2>
                                <p className="text-xs text-slate-500 dark:text-slate-400">MZ세대 대화법, 나는 얼마나 잘 해쳐나갈 수 있을까?</p>
                            </div>
                            <div className="bg-slate-50 dark:bg-slate-900 p-4 rounded-xl text-left text-xs leading-relaxed text-slate-500 dark:text-slate-400 space-y-1">
                                <p className="font-bold text-slate-700 dark:text-slate-200">🔍 테스트 안내:</p>
                                <p>• 총 문항: 5개 선다형 문제</p>
                                <p>• 소요시간: 약 1~2분 내외</p>
                                <p>• 결과 유형: 신조어 마스터부터 트렌드 구제 금융형까지 맞춤 진단</p>
                            </div>
                            <button 
                                onClick={startQuiz}
                                className="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3.5 rounded-xl shadow-md transition-all">
                                테스트 시작하기
                            </button>
                        </div>
                    )}

                    {gameState === 'playing' && (
                        <div className="p-6 md:p-8 space-y-6">
                            {/* Quiz Header Info */}
                            <div className="flex justify-between items-center border-b border-slate-100 dark:border-slate-700 pb-3">
                                <span className="text-xs text-indigo-600 dark:text-indigo-400 font-extrabold uppercase">문제 {currentIdx + 1} / {QUIZ_QUESTIONS.length}</span>
                                <span className="text-xs text-slate-400 dark:text-slate-500">정답 개수: {score}</span>
                            </div>

                            {/* Question Card */}
                            <div className="bg-slate-50 dark:bg-slate-900/60 p-5 rounded-xl border border-slate-100 dark:border-slate-800">
                                <p className="text-base md:text-lg font-bold text-slate-800 dark:text-slate-100 whitespace-pre-line leading-relaxed">
                                    {QUIZ_QUESTIONS[currentIdx].question}
                                </p>
                            </div>

                            {/* Multi Choices */}
                            <div className="space-y-2.5">
                                {QUIZ_QUESTIONS[currentIdx].options.map((opt, idx) => {
                                    let btnStyle = 'border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700/60 text-slate-700 dark:text-slate-200';
                                    
                                    if (isAnswered) {
                                        if (idx === QUIZ_QUESTIONS[currentIdx].correct) {
                                            btnStyle = 'bg-emerald-50 dark:bg-emerald-950/50 border-emerald-400 dark:border-emerald-700 text-emerald-700 dark:text-emerald-300 font-bold ring-2 ring-emerald-500/20';
                                        } else if (idx === selectedAnswer) {
                                            btnStyle = 'bg-red-50 dark:bg-red-950/50 border-red-400 dark:border-red-900 text-red-700 dark:text-red-400 font-bold';
                                        } else {
                                            btnStyle = 'opacity-60 border-slate-200 dark:border-slate-800 text-slate-400 dark:text-slate-500';
                                        }
                                    }

                                    return (
                                        <button
                                            key={idx}
                                            onClick={() => handleOptionClick(idx)}
                                            disabled={isAnswered}
                                            className={`w-full p-4 rounded-xl border text-left text-xs md:text-sm transition-all flex items-center justify-between ${btnStyle}`}>
                                            <span>{idx + 1}. {opt}</span>
                                            {isAnswered && idx === QUIZ_QUESTIONS[currentIdx].correct && (
                                                <i data-lucide="check" className="w-4 h-4 text-emerald-500"></i>
                                            )}
                                        </button>
                                    );
                                })}
                            </div>

                            {/* Explanation Show */}
                            {isAnswered && (
                                <div className="bg-indigo-50/50 dark:bg-indigo-950/20 p-4 rounded-xl border border-indigo-100/60 dark:border-indigo-900/40 text-xs text-indigo-900 dark:text-indigo-200 leading-relaxed">
                                    <strong className="block text-indigo-700 dark:text-indigo-300 font-bold mb-1">💡 풀이 및 유래:</strong>
                                    {QUIZ_QUESTIONS[currentIdx].explanation}
                                </div>
                            )}

                            {/* Bottom Navigation */}
                            {isAnswered && (
                                <button 
                                    onClick={handleNext}
                                    className="w-full bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 font-bold py-3.5 rounded-xl transition-all hover:bg-slate-800 flex items-center justify-center space-x-2">
                                    <span>{currentIdx < QUIZ_QUESTIONS.length - 1 ? '다음 문제 이동' : '최종 점수 확인'}</span>
                                    <i data-lucide="chevron-right" className="w-4 h-4"></i>
                                </button>
                            )}
                        </div>
                    )}

                    {gameState === 'result' && (
                        <div className="p-8 text-center space-y-6">
                            <div className="w-20 h-20 rounded-full bg-gradient-to-tr from-indigo-500 to-pink-500 flex items-center justify-center text-white text-3xl font-black mx-auto shadow-xl">
                                {score} / 5
                            </div>
                            <div className="space-y-2">
                                <h3 className="text-xl font-bold text-slate-500 dark:text-slate-400">당신의 신조어 독해 점수 결과</h3>
                                <h4 className="text-2xl font-black text-indigo-600 dark:text-indigo-400">{getResultType().title}</h4>
                                <p className="text-xs text-slate-500 dark:text-slate-400 max-w-sm mx-auto leading-relaxed mt-1">
                                    {getResultType().desc}
                                </p>
                            </div>

                            <div className="flex gap-3 pt-2">
                                <button 
                                    onClick={startQuiz}
                                    className="flex-1 bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 hover:text-slate-900 text-slate-700 dark:text-white font-bold py-3 rounded-xl transition-all text-xs">
                                    다시 테스트하기
                                </button>
                                <button 
                                    onClick={() => {
                                        const dummy = document.createElement('textarea');
                                        dummy.value = `나의 신조어 문해력 테스트 결과: [${getResultType().title}] 획득! 여러분도 측정해보세요!`;
                                        document.body.appendChild(dummy);
                                        dummy.select();
                                        document.execCommand('copy');
                                        document.body.removeChild(dummy);
                                        triggerToast('결과 공유 멘트가 복사되었습니다!');
                                    }}
                                    className="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl shadow-md transition-all text-xs flex items-center justify-center space-x-1.5">
                                    <i data-lucide="share-2" className="w-3.5 h-3.5"></i>
                                    <span>결과 복사하기</span>
                                </button>
                            </div>
                        </div>
                    )}
                </div>
            );
        }
    </script>

    <script type="text/babel">
        function SubmitSection({ dictionary, setDictionary, triggerToast }) {
            const [word, setWord] = useState('');
            const [standard, setStandard] = useState('');
            const [definition, setDefinition] = useState('');
            const [example, setExample] = useState('');
            const [category, setCategory] = useState('줄임말');
            const [rating, setRating] = useState(3);
            const [origin, setOrigin] = useState('');

            const handleSubmit = (e) => {
                e.preventDefault();

                // Validation
                if (!word.trim() || !standard.trim() || !definition.trim()) {
                    triggerToast('단어 이름, 번역어(대치), 뜻풀이는 반드시 기입하셔야 합니다.', 'error');
                    return;
                }

                // Check Duplicates
                const duplicate = dictionary.some(w => w.word.trim() === word.trim());
                if (duplicate) {
                    triggerToast('이미 사전에 같은 이름으로 등록된 단어가 있습니다.', 'error');
                    return;
                }

                // Append new word
                const newSlang = {
                    id: Date.now(),
                    word: word.trim(),
                    standard: standard.trim(),
                    definition: definition.trim(),
                    origin: origin.trim() || '사용자 커스텀 입력 단어입니다.',
                    category,
                    rating: parseInt(rating),
                    example: example.trim() || `${word.trim()} 한 번만 더 써보자.`
                };

                setDictionary(prev => [newSlang, ...prev]);
                triggerToast('새로운 신조어가 나만의 번역 사전에 영구 추가되었습니다!');
                
                // Reset Forms
                setWord('');
                setStandard('');
                setDefinition('');
                setOrigin('');
                setExample('');
                setCategory('줄임말');
                setRating(3);
            };

            return (
                <div className="max-w-xl mx-auto bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl shadow-xl p-6 md:p-8 space-y-6 animate-fadeIn">
                    <div className="space-y-1 text-center">
                        <h2 className="text-2xl font-black text-slate-800 dark:text-white">➕ 나만의 신조어 사전에 등록</h2>
                        <p className="text-xs text-slate-500 dark:text-slate-400">
                            나만의 은어나 친구끼리 쓰는 줄임말이 있나요? 직접 등록하면 [번역기] 탭에서 실시간 파싱 및 주석 번역이 즉각 동작합니다.
                        </p>
                    </div>

                    <form onSubmit={handleSubmit} className="space-y-4">
                        <div className="grid grid-cols-2 gap-4">
                            <div>
                                <label className="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase mb-1.5">단어 이름 (필수)</label>
                                <input
                                    type="text"
                                    placeholder="예: 최최차차"
                                    value={word}
                                    onChange={(e) => setWord(e.target.value)}
                                    className="w-full px-3.5 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-transparent text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all text-slate-800 dark:text-slate-100"
                                />
                            </div>
                            <div>
                                <label className="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase mb-1.5">표준어 대치 (필수)</label>
                                <input
                                    type="text"
                                    placeholder="예: 최애는 최애고 차은우는 차은우"
                                    value={standard}
                                    onChange={(e) => setStandard(e.target.value)}
                                    className="w-full px-3.5 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-transparent text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all text-slate-800 dark:text-slate-100"
                                />
                            </div>
                        </div>

                        <div className="grid grid-cols-2 gap-4">
                            <div>
                                <label className="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase mb-1.5">카테고리</label>
                                <select 
                                    value={category}
                                    onChange={(e) => setCategory(e.target.value)}
                                    className="w-full px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all text-slate-800 dark:text-slate-100">
                                    <option value="줄임말">줄임말</option>
                                    <option value="신조어">신조어</option>
                                    <option value="밈">밈</option>
                                    <option value="기타">기타</option>
                                </select>
                            </div>
                            <div>
                                <label className="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase mb-1.5">트렌디성 점수</label>
                                <select 
